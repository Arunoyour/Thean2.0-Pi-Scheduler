{
  "jobs": [
    {
      "name": "heartbeat",
      "url": "http://192.168.1.100/api/heartbeat",
      "interval_seconds": 60,
      "body": { "device": "pi", "status": "ok" },
      "connect_timeout": 5,
      "read_timeout": 10,
      "retry_count": 5,
      "retry_delay": 30
    },
    {
      "name": "sensor-data",
      "url": "http://192.168.1.100/api/sensor",
      "interval_seconds": 300,
      "body": null,
      "connect_timeout": 5,
      "read_timeout": 10,
      "retry_count": 5,
      "retry_delay": 30
    }
  ]
}
